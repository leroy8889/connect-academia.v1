# ── StudyLink — Configuration ─────────────────────
# Copiez ce fichier vers .env et remplissez les valeurs

# Application
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost

# Base de données
DB_HOST=localhost
DB_PORT=3306
DB_NAME=studylink_db
DB_USER=root
DB_PASS=root

# Session
SESSION_NAME=studylink_sess

# Upload
MAX_UPLOAD_MB=10
